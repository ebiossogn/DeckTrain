generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  password           String
  role               String    @default("JUNIOR_ADMIN")
  permissions        String?
  isBlocked          Boolean   @default(false)
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
}

model AppUser {
  id                      String        @id @default(cuid())
  email                   String        @unique
  name                    String
  password                String
  type                    String        @default("participant")
  isActive                Boolean       @default(true)
  emailVerified           Boolean       @default(false)
  verificationToken       String?
  verificationTokenExpiry DateTime?
  googleId                String?       @unique
  tempPassword            Boolean       @default(false)
  moduleIds               String?
  firstLogin              Boolean       @default(true)
  onboardingStep          Int           @default(0)
  certificates            Certificate[]
  createdAt               DateTime      @default(now())
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  userAgent String?
  createdAt DateTime @default(now())
}

model Module {
  id           String          @id @default(cuid())
  title        String
  description  String?
  order        Int
  slides       Slide[]
  exercises    Exercise[]
  sessions     AgendaSession[]
  resources    Resource[]
  liveSessions LiveSession[]
  certificates Certificate[]
  isDeleted    Boolean         @default(false)
  deletedAt    DateTime?
  createdAt    DateTime        @default(now())
}

model LiveSession {
  id                String    @id @default(cuid())
  code              String    @unique
  moduleId          String
  module            Module    @relation(fields: [moduleId], references: [id])
  hostId            String
  currentSlideIndex Int       @default(0)
  isActive          Boolean   @default(true)
  isBlurred         Boolean   @default(false)
  isBlackScreen     Boolean   @default(false)
  viewerCount       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  endedAt           DateTime?
}

model Slide {
  id           String    @id @default(cuid())
  moduleId     String
  module       Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type         String
  order        Int
  content      String
  speakerNotes String?
  timerMinutes Int?
  transition   String?
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
}

model Exercise {
  id         String    @id @default(cuid())
  moduleId   String
  module     Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type       String
  title      String
  content    String
  difficulty String
  solution   String?
  order      Int
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model AgendaSession {
  id          String    @id @default(cuid())
  title       String
  type        String    @default("formation")
  startDate   DateTime
  endDate     DateTime
  startTime   String?
  endTime     String?
  description String?
  location    String?
  status      String    @default("planifie")
  color       String?
  moduleId    String?
  module      Module?   @relation(fields: [moduleId], references: [id])
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String
  url         String
  moduleId    String?
  module      Module?  @relation(fields: [moduleId], references: [id])
  createdAt   DateTime @default(now())
}

model Survey {
  id          String           @id @default(cuid())
  title       String
  description String?
  code        String           @unique
  isActive    Boolean          @default(true)
  isLive      Boolean          @default(false)
  questions   SurveyQuestion[]
  isDeleted   Boolean          @default(false)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
}

model SurveyQuestion {
  id        String           @id @default(cuid())
  surveyId  String
  survey    Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  type      String
  order     Int
  title     String
  options   String?
  multiple  Boolean          @default(false)
  responses SurveyResponse[]
  createdAt DateTime         @default(now())
}

model SurveyResponse {
  id         String         @id @default(cuid())
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      String
  respondent String?
  createdAt  DateTime       @default(now())
}

model AppSettings {
  id               String  @id @default("singleton")
  solutionsVisible Boolean @default(false)
  accentColor      String  @default("#00D4FF")
  trainingTitle    String  @default("Formation Tech")
  trainingSubtitle String  @default("Mai 2026")
  trainerName      String  @default("CHRIST J.")
}

model Certificate {
  id            String   @id @default(cuid())
  participantId String
  participant   AppUser  @relation(fields: [participantId], references: [id])
  moduleId      String
  module        Module   @relation(fields: [moduleId], references: [id])
  issuedBy      String
  issuedAt      DateTime @default(now())
  code          String   @unique
  pdfUrl        String?
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  userRole   String?
  action     String
  resource   String
  resourceId String?
  details    String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
